# RunIt Maps Configuration
# Copy to .env and fill in values

RUST_LOG=info

# Valhalla engine URL (Docker: http://valhalla:8002, local: http://localhost:8002)
VALHALLA_URL=http://localhost:8002

# gRPC server port
GRPC_PORT=50051

# OSM data source
OSM_DOWNLOAD_BASE_URL=https://download.geofabrik.de/africa

# Default regions (comma-separated)
REGIONS=medilag-campus

# Tile directories
TILE_DIR=/data/tiles
OSM_DATA_DIR=/data/osm
CUSTOM_PATHS_DIR=/data/custom_paths
